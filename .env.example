# ==============================================================================
# StadiumIQ - AI Stadium Intelligence Platform (FIFA World Cup 2026)
# Environment Variables Configuration
# ==============================================================================

# Groq API Key: Required for llama-3.3-70b-versatile LLM interactions
# Obtain yours from: https://console.groq.com/
GROQ_API_KEY="your_groq_api_key_here"

# Application URL (Optional, injected by platform at runtime)
# Used for routing, self-reference, or logging
APP_URL="https://localhost:3000"

# Application Environment Mode: "production" or "development"
APP_ENV="development"

# Logging Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"
